<group name="vsec,lolbas,windows,sysmon,">

  <rule id="100100" level="0">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^1$|^4688$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\AddinUtil\.exe$</field>
    <description>LOLBAS T1218 AddinUtil.exe execution</description>
    <group>T1218,lolbas_addinutil,</group>
  </rule>

  <rule id="100102" level="12">
    <if_sid>100100</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(-AddinRoot:|--AddinRoot:|/AddinRoot:|-PipelineRoot:|--PipelineRoot:|/PipelineRoot:).*(?:\\temp\\|\\user\\|\\downloads?\\|\\public\\|\.)</field>
    <description>LOLBAS T1218 AddinUtil.exe called with sensitive paths</description>
    <group>T1218,lolbas_addinutil,</group>
  </rule>

  <rule id="100103" level="15">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^1$|^4688$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\AddinUtil\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell|pwsh|calc)\.exe$</field>
    <description>LOLBAS T1218 AddinUtil.exe spawned suspicious child process</description>
    <group>T1218,lolbas_addinutil,</group>
  </rule>

  <rule id="100104" level="12">
    <if_sid>100100</if_sid>
    <field name="win.eventdata.image" type="pcre2" negate="yes">(?i)(\\Microsoft\.NET\\Framework(64)?|\\WinSxS)\\.*</field>
    <description>LOLBAS T1218 AddinUtil.exe executed outside default directories</description>
    <group>T1218,lolbas_addinutil,</group>
  </rule>

  <rule id="100105" level="12">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^3$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\AddinUtil\.exe$</field>
    <description>LOLBAS T1218 AddinUtil.exe initiated outbound network connection</description>
    <group>T1218,lolbas_addinutil,</group>
  </rule>

  <rule id="100106" level="15">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^1$|^4688$</field>
    <field name="win.eventdata.originalFileName" type="pcre2">(?i)ysoserial(\.net)?\.exe</field>
    <description>CRITICAL ysoserial.exe executed - payload generator</description>
    <group>T1218,lolbas_addinutil,</group>
  </rule>

  <rule id="100200" level="12">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^4104$</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)ms-appinstaller://\?source=https?://</field>
    <description>LOLBAS T1105 ms-appinstaller URI found in PowerShell ScriptBlock</description>
    <group>T1105,lolbas_appinstaller,</group>
  </rule>

  <rule id="100201" level="12">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^1$|^4688$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\AppInstaller\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)ms-appinstaller://\?source=https?://</field>
    <description>LOLBAS T1105 AppInstaller.exe launched with remote URI</description>
    <group>T1105,lolbas_appinstaller,</group>
  </rule>

  <rule id="100202" level="10">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^11$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\\Microsoft\.DesktopAppInstaller_[0-9a-z]+\\AC\\INetCache\\.*</field>
    <description>LOLBAS T1105 File created in AppInstaller INetCache</description>
    <group>T1105,lolbas_appinstaller,</group>
  </rule>

  <rule id="100203" level="8">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^3$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\AppInstaller\.exe$</field>
    <description>LOLBAS T1105 AppInstaller.exe initiated network connection</description>
    <group>T1105,lolbas_appinstaller,</group>
  </rule>

  <rule id="100210" level="0">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^1$|^4688$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\aspnet_compiler\.exe$</field>
    <description>LOLBAS T1127 aspnet_compiler.exe executed</description>
    <group>T1127,lolbas_aspnet,</group>
  </rule>

  <rule id="100211" level="12">
    <if_sid>100210</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(\\temp|\\downloads?|\\public)\\.*</field>
    <description>LOLBAS T1127 aspnet_compiler.exe loaded from sensitive writable path</description>
    <group>T1127,lolbas_aspnet,</group>
  </rule>

  <rule id="100212" level="14">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^1$|^4688$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\aspnet_compiler\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell|pwsh)\.exe$</field>
    <description>LOLBAS T1127 aspnet_compiler.exe spawned shell child</description>
    <group>T1127,lolbas_aspnet,</group>
  </rule>

  <rule id="100300" level="0">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^1$|^4688$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\at\.exe$</field>
    <description>LOLBAS T1053.002 At.exe process creation</description>
    <group>T1053.002,lolbas_at,</group>
  </rule>

  <rule id="100301" level="12">
    <if_sid>100300</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)/interactive\b</field>
    <description>LOLBAS T1053.002 At.exe called with interactive flag</description>
    <group>T1053.002,lolbas_at,</group>
  </rule>

  <rule id="100302" level="13">
    <if_sid>100300</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\\\\[a-z0-9_\-\.]+\\.*</field>
    <description>LOLBAS T1053.002 At.exe called with UNC remote path</description>
    <group>T1053.002,lolbas_at,</group>
  </rule>

  <rule id="100320" level="0">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^1$|^4688$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\ATBroker\.exe$</field>
    <description>LOLBAS T1546.008 ATBroker.exe process creation</description>
    <group>T1546.008,lolbas_atbroker,</group>
  </rule>

  <rule id="100321" level="12">
    <if_sid>100320</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)/start\s+(?!(narrator|animations|audiodescription|caretbrowsing|caretwidth|colorfiltering|cursorscheme|filterkeys|focusborderheight|focusborderwidth|highcontrast|keyboardcues|keyboardpref|magnifierpane|messageduration|minimumhitradius|mousekeys|osk|overlappedcontent|showsounds|soundsentry|stickykeys|togglekeys|windowarranging|windowtracking|windowtrackingtimeout|windowtrackingzorder)\b)</field>
    <description>LOLBAS T1546.008 ATBroker.exe start with non-standard AT name</description>
    <group>T1546.008,lolbas_atbroker,</group>
  </rule>

  <rule id="100322" level="13">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^(12|13|14)$</field>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\(SOFTWARE\\Microsoft|Software\\Microsoft)\\Windows NT\\CurrentVersion\\Accessibility\\(ATs|Configuration)</field>
    <description>LOLBAS T1546.008 Registry mod to Accessibility ATs Configuration</description>
    <group>T1546.008,lolbas_atbroker,</group>
  </rule>

  <rule id="100330" level="3">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^1$|^4688$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\bash\.exe$</field>
    <description>LOLBAS T1202 bash.exe legacy process creation</description>
    <group>T1202,lolbas_bash,</group>
  </rule>

  <rule id="100331" level="12">
    <if_sid>100330</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\bbash(\.exe)?\s+-c\s+</field>
    <description>LOLBAS T1202 bash.exe shell flag used</description>
    <group>T1202,lolbas_bash,</group>
  </rule>

  <rule id="100332" level="13">
    <if_sid>100330</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(/dev/tcp|tcp-connect|\bnc\b|\bncat\b|curl\s|wget\s|python.*socket|&gt;)</field>
    <description>LOLBAS T1202 bash.exe command contains network or shell escape patterns</description>
    <group>T1202,lolbas_bash,</group>
  </rule>

  <rule id="100333" level="13">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^1$|^4688$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\bash\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell|pwsh)\.exe$</field>
    <description>LOLBAS T1202 bash.exe spawned Windows shell</description>
    <group>T1202,lolbas_bash,</group>
  </rule>

  <rule id="100334" level="13">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^3$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\bash\.exe$</field>
    <description>LOLBAS T1202 bash.exe initiated network connection</description>
    <group>T1202,lolbas_bash,</group>
  </rule>

  <rule id="100400" level="12">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^1$|^4688$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\bitsadmin\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(/transfer\s|/addfile\s).*https?://</field>
    <description>LOLBAS T1197 bitsadmin.exe transfer or addfile with URL</description>
    <group>T1197,T1105,lolbas_bitsadmin,</group>
  </rule>

  <rule id="100402" level="14">
    <decoded_as>json</decoded_as>
    <field name="win.system.eventID">^1$|^4688$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\bitsadmin\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)/setnotifycmdline\s</field>
    <description>LOLBAS T1197 bitsadmin.exe setnotifycmdline persistence callback</description>
    <group>T1197,lolbas_bitsadmin,</group>
  </rule>

</group>
